# Copy this to .env and fill in your values.
# Model routing is handled by LiteLLM. Full list: https://docs.litellm.ai/docs/providers

# ---------------------------------------------------------------------------
# API keys — add whichever providers you have access to.
# Auto mode will pick the best available model for each role.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...      # enables anthropic/* models
OPENAI_API_KEY=sk-...             # enables openai/* models
GEMINI_API_KEY=...                # enables gemini/* models
GROQ_API_KEY=...                  # enables groq/* models
MISTRAL_API_KEY=...               # enables mistral/* models

# ---------------------------------------------------------------------------
# Model config — three modes, pick one:
#
# MODE 1 — Auto (recommended to start)
#   Leave all model vars unset. The system picks the best available model
#   for each role based on which API keys are present.
#
# MODE 2 — Global override (all roles use the same model)
#   AGENT_MODEL=gemini/gemini-flash-latest
#
# MODE 3 — Per-role assignment (full control)
#   ORCHESTRATOR_MODEL=gemini/gemini-pro-latest    # goal decomposition
#   PLANNER_MODEL=anthropic/claude-sonnet-4-6      # workspace exploration + phased plan
#   SUBAGENT_MODEL=anthropic/claude-sonnet-4-6     # code writing
#   REVIEWER_MODEL=gemini/gemini-pro-latest        # quality gate
#   REFINER_MODEL=gemini/gemini-flash-latest       # fix planning
#
# Per-role vars override AGENT_MODEL which overrides auto.
# ---------------------------------------------------------------------------

# --- Windows Unicode fix (safe to leave on all platforms) -----------
PYTHONUTF8=1

# --- Agent settings -------------------------------------------------
MAX_ITERATIONS=3
MAX_SUBAGENTS=7              # orchestrator may choose 1–N subtasks; hard cap at N
AGENT_MAX_TOKENS=8096
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs

# --- Linear (board-updater skill) -----------------------------------
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...

# --- GitHub (PR creation + board updates) ---------------------------
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo
GITHUB_BASE_BRANCH=main          # branch to open PRs against (default: main)
GITHUB_PROJECT_NUMBER=1          # Projects v2 board number (from the project URL)

# --- Browser validator ----------------------------------------------
BROWSER_VALIDATOR_ENABLED=false   # set true to enable LLM-driven UI testing
BROWSER_TEST_MAX_STEPS=20         # max tool-use steps per browser test session
BROWSER_ACTION_TIMEOUT=10000      # Playwright action timeout in milliseconds

# --- Webhook server (talon serve) ----------------------
# Label that must be present on an issue to trigger a run (set "" to accept all)
WEBHOOK_LABEL=agent-task
LINEAR_WEBHOOK_SECRET=...      # from Linear → Settings → API → Webhooks
GITHUB_WEBHOOK_SECRET=...      # from GitHub → Repo Settings → Webhooks
MAX_CONCURRENT_RUNS=3          # max simultaneous loop executions

#oAuth app credentials (for GitHub login flow in the frontend)
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...