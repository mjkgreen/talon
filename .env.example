# Copy this to .env and fill in your values.
# Model routing is handled by LiteLLM — set AGENT_MODEL to any supported model.
# Full list: https://docs.litellm.ai/docs/providers

# --- Model selection (change this one line to switch providers) -----
AGENT_MODEL=anthropic/claude-sonnet-4-6

# --- API keys (only the one matching AGENT_MODEL is required) -------
ANTHROPIC_API_KEY=sk-ant-...      # anthropic/...
OPENAI_API_KEY=sk-...             # openai/...
GEMINI_API_KEY=...                # gemini/...
GROQ_API_KEY=...                  # groq/...
MISTRAL_API_KEY=...               # mistral/...

# --- Agent settings -------------------------------------------------
MAX_ITERATIONS=3
AGENT_MAX_TOKENS=8096
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs

# --- Linear (board-updater skill) -----------------------------------
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...

# --- GitHub Projects (alternative to Linear) ------------------------
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# --- Browser validator ----------------------------------------------
BROWSER_VALIDATOR_ENABLED=false
