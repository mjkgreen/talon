# Copy this to .env and fill in your values

# --- Provider selection -------------------------------------------
# "anthropic" (default, with prompt caching) or "openai"
AGENT_PROVIDER=anthropic

# --- Anthropic (Claude Code / claude-sonnet-4-6) ------------------
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-sonnet-4-6

# --- OpenAI (Codex CLI / gpt-4o) ----------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Shared agent settings ----------------------------------------
MAX_ITERATIONS=3
AGENT_MAX_TOKENS=8096
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs

# --- Linear (board-updater skill) ---------------------------------
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...

# --- GitHub Projects (alternative to Linear) ----------------------
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# --- Browser validator --------------------------------------------
BROWSER_VALIDATOR_ENABLED=false
