# Copy this to .env and fill in your values.
# Model routing is handled by LiteLLM. Full list: https://docs.litellm.ai/docs/providers

# ---------------------------------------------------------------------------
# API keys — add whichever providers you have access to.
# Auto mode will pick the best available model for each role.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...      # enables anthropic/* models
OPENAI_API_KEY=sk-...             # enables openai/* models
GEMINI_API_KEY=...                # enables gemini/* models
GROQ_API_KEY=...                  # enables groq/* models
MISTRAL_API_KEY=...               # enables mistral/* models

# ---------------------------------------------------------------------------
# Model config — three modes, pick one:
#
# MODE 1 — Auto (recommended to start)
#   Leave all model vars unset. The system picks the best available model
#   for each role based on which API keys are present.
#
# MODE 2 — Global override (all roles use the same model)
#   AGENT_MODEL=gemini/gemini-2.0-flash
#
# MODE 3 — Per-role assignment (full control)
#   ORCHESTRATOR_MODEL=gemini/gemini-1.5-pro    # goal decomposition
#   SUBAGENT_MODEL=anthropic/claude-sonnet-4-6  # code writing
#   REVIEWER_MODEL=gemini/gemini-1.5-pro        # quality gate
#   REFINER_MODEL=gemini/gemini-2.0-flash       # fix planning
#
# Per-role vars override AGENT_MODEL which overrides auto.
# ---------------------------------------------------------------------------

# --- Agent settings -------------------------------------------------
MAX_ITERATIONS=3
AGENT_MAX_TOKENS=8096
WORKSPACE_DIR=./workspace
RUNS_DIR=./runs

# --- Linear (board-updater skill) -----------------------------------
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=...

# --- GitHub Projects (alternative to Linear) ------------------------
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# --- Browser validator ----------------------------------------------
BROWSER_VALIDATOR_ENABLED=false
